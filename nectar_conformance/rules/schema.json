{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "definition": {
    "type": "object",
    "additionalProperties": false,
    "required": ["id", "title", "selector"],
    "$defs": {
      "base_selector": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": {
          "type": {"enum": ["all", "contains_class", "has_resource", "fact_match", "site"]},
          "class": {"type": "string"},
          "resource_type": {"type": "string"},
          "resource_title": {"type": "string"},
          "path": {"type": "string"},
          "value": {},
          "match": {"enum": ["equals", "present"]}
        }
      }
    },
    "properties": {
      "id": {"type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9_]+)+$"},
      "title": {"type": "string", "minLength": 1},
      "description": {"type": "string"},
      "spec_section": {"type": "string"},
      "kind": {"enum": ["declarative", "plugin"]},
      "optional": {"type": "boolean"},
      "selector": {
        "anyOf": [
          {"$ref": "#/$defs/base_selector"},
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "selectors"],
            "properties": {
              "type": {"const": "all_of"},
              "selectors": {
                "type": "array",
                "minItems": 2,
                "items": {"$ref": "#/$defs/base_selector"}
              }
            }
          }
        ]
      },
      "query": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type"],
        "properties": {
          "type": {"enum": ["fact", "resource_param", "count", "class_present"]},
          "path": {"type": "string"},
          "resource_type": {"type": "string"},
          "resource_title": {"type": "string"},
          "param": {"type": "string"},
          "extract": {"type": "string"},
          "class": {"type": "string"}
        }
      },
      "assertion": {
        "type": "object",
        "additionalProperties": false,
        "required": ["op"],
        "properties": {
          "op": {
            "enum": [
              "equals", "not_equals", "regex", "semver_gte", "semver_eq",
              "in_set", "count_gte", "count_eq", "count_lte", "all_equal",
              "present", "absent"
            ]
          }
        }
      },
      "remediation": {
        "type": "object",
        "additionalProperties": false,
        "required": ["guidance"],
        "properties": {
          "guidance": {"type": "string"},
          "hiera_key": {"type": "string"},
          "hint_file": {"type": "string"}
        }
      },
      "plugin": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": {"type": "string"},
          "params": {"type": "object"}
        }
      }
    },
    "allOf": [
      {
        "if": {"properties": {"kind": {"const": "plugin"}}, "required": ["kind"]},
        "then": {"required": ["plugin"]},
        "else": {"required": ["query", "assertion"]}
      }
    ]
  },
  "changelog": {
    "type": "object",
    "additionalProperties": false,
    "required": ["entries"],
    "properties": {
      "tags": {
        "type": "object",
        "propertyNames": {"pattern": "^[0-9]+\\.[0-9]+$"},
        "additionalProperties": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"}
      },
      "entries": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": ["check_id", "effective"],
          "properties": {
            "check_id": {"type": "string", "pattern": "^[a-z0-9]+(\\.[a-z0-9_]+)+$"},
            "value": {},
            "effective": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
            "due": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
            "tier": {"enum": ["all", "test", "prod"]},
            "note": {"type": "string"}
          }
        }
      }
    }
  }
}
